<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayPanel"
    android:layout_width="180dp"
    android:layout_height="wrap_content"
    android:background="@drawable/overlay_panel_background"
    android:elevation="8dp"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:id="@+id/queueTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:maxLines="2"
        android:text="评论队列：0/0"
        android:textColor="#FF555555"
        android:textSize="12sp" />

    <Button
        android:id="@+id/readCommentButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:minWidth="96dp"
        android:minHeight="36dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:text="读取评论" />

    <Button
        android:id="@+id/openProfileButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:minWidth="96dp"
        android:minHeight="36dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:text="下一个" />

    <Button
        android:id="@+id/readProfileInfoButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:minWidth="96dp"
        android:minHeight="36dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:text="读取主页信息" />

    <Button
        android:id="@+id/collapseButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:minWidth="96dp"
        android:minHeight="36dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:text="收起" />
</LinearLayout>
