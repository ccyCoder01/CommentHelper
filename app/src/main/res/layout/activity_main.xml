<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF4F6F8"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/settingsPage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingBottom="24dp">

                <TextView
                    android:id="@+id/titleTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/main_title"
                    android:textColor="#FF20262D"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/accessibilityStatusCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/status_card_disabled_background"
                    android:elevation="1dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="辅助功能状态"
                        android:textColor="#FF20262D"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/accessibilityPermissionTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="辅助功能未开启"
                        android:textColor="#FF7A4B2A"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/openAccessibilitySettingsButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/button_primary_background"
                        android:minWidth="92dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="去开启"
                        android:textColor="#FFFFFFFF"
                        app:backgroundTint="@null" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/card_background"
                    android:elevation="1dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="固定话术"
                        android:textColor="#FF20262D"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/fixedTextEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/field_background"
                        android:gravity="top|start"
                        android:inputType="textMultiLine"
                        android:minHeight="64dp"
                        android:minLines="2"
                        android:paddingStart="12dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="8dp"
                        android:textColor="#FF20262D"
                        android:textSize="15sp" />

                    <Button
                        android:id="@+id/saveFixedTextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:layout_gravity="end"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/button_primary_background"
                        android:minWidth="92dp"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:text="保存话术"
                        android:textColor="#FFFFFFFF" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/card_background"
                    android:elevation="1dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="用户画像"
                        android:textColor="#FF20262D"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="性别"
                        android:textColor="#FF4C5663"
                        android:textSize="14sp" />

                    <RadioGroup
                        android:id="@+id/targetGenderRadioGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/targetMaleRadioButton"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:buttonTint="#FF2F3A45"
                            android:text="男"
                            android:textColor="#FF20262D" />

                        <RadioButton
                            android:id="@+id/targetFemaleRadioButton"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:layout_marginStart="24dp"
                            android:buttonTint="#FF2F3A45"
                            android:text="女"
                            android:textColor="#FF20262D" />
                    </RadioGroup>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="IP"
                        android:textColor="#FF4C5663"
                        android:textSize="14sp" />

                    <Spinner
                        android:id="@+id/targetIpLocationSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/field_background"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="要求"
                        android:textColor="#FF4C5663"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/profileRequirementEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/field_background"
                        android:gravity="top|start"
                        android:inputType="textMultiLine"
                        android:minHeight="64dp"
                        android:minLines="2"
                        android:paddingStart="12dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="8dp"
                        android:textColor="#FF20262D"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="LLM API Key"
                        android:textColor="#FF4C5663"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/llmApiKeyEditText"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/field_background"
                        android:inputType="textPassword"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:singleLine="true"
                        android:textColor="#FF20262D"
                        android:textSize="15sp" />

                    <Button
                        android:id="@+id/saveProfileCriteriaButton"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:layout_gravity="end"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/button_primary_background"
                        android:minWidth="92dp"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:text="保存画像"
                        android:textColor="#FFFFFFFF" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/statsPage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="归档管理"
                    android:textColor="#FF20262D"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/card_background"
                    android:elevation="1dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="归档列表"
                        android:textColor="#FF20262D"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ListView
                        android:id="@+id/statsListView"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/list_background"
                        android:choiceMode="singleChoice"
                        android:divider="#FFE4E8EE"
                        android:dividerHeight="1dp"
                        android:padding="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/archivePrevPageButton"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:background="@drawable/button_secondary_background"
                            android:minWidth="72dp"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="上一页"
                            android:textColor="#FF2F3A45"
                            android:textSize="13sp"
                            app:backgroundTint="@null" />

                        <TextView
                            android:id="@+id/archivePageTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_marginEnd="14dp"
                            android:text="第 0/0 页"
                            android:textColor="#FF4C5663"
                            android:textSize="14sp" />

                        <Button
                            android:id="@+id/archiveNextPageButton"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:background="@drawable/button_secondary_background"
                            android:minWidth="72dp"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="下一页"
                            android:textColor="#FF2F3A45"
                            android:textSize="13sp"
                            app:backgroundTint="@null" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/card_background"
                    android:elevation="1dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="归档编辑"
                        android:textColor="#FF20262D"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="小红书号"
                        android:textColor="#FF4C5663"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/xhsIdEditText"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/field_background"
                        android:inputType="text"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textColor="#FF20262D"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="判断结果"
                        android:textColor="#FF4C5663"
                        android:textSize="14sp" />

                    <Spinner
                        android:id="@+id/labelStatusSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/field_background"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="原因"
                        android:textColor="#FF4C5663"
                        android:textSize="14sp" />

                    <Spinner
                        android:id="@+id/labelReasonSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/field_background"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="end"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/deleteRecordButton"
                            android:layout_width="wrap_content"
                            android:layout_height="42dp"
                            android:background="@drawable/button_danger_background"
                            android:minWidth="84dp"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="删除"
                            android:textColor="#FFB64A4A"
                            app:backgroundTint="@null" />

                        <Button
                            android:id="@+id/saveRecordButton"
                            android:layout_width="wrap_content"
                            android:layout_height="42dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/button_primary_background"
                            android:minWidth="84dp"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="保存"
                            android:textColor="#FFFFFFFF" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/analyticsPage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="数据分析"
                    android:textColor="#FF20262D"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/card_background"
                    android:elevation="1dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="标签结果分布"
                        android:textColor="#FF20262D"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <com.ccy.xhscommenthelper.analytics.SemiRingChartView
                        android:id="@+id/semiRingChartView"
                        android:layout_width="match_parent"
                        android:layout_height="210dp"
                        android:layout_marginTop="10dp" />

                    <TextView
                        android:id="@+id/semiRingLegendTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="#FF4C5663"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/card_background"
                    android:elevation="1dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="失败原因分布"
                        android:textColor="#FF20262D"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <com.ccy.xhscommenthelper.analytics.FailureReasonBarChartView
                        android:id="@+id/failureReasonBarChartView"
                        android:layout_width="match_parent"
                        android:layout_height="260dp"
                        android:layout_marginTop="10dp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FFFFFFFF"
        android:elevation="8dp"
        app:itemActiveIndicatorStyle="@null"
        app:itemIconTint="@color/bottom_navigation_item_color"
        app:itemTextColor="@color/bottom_navigation_item_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/main_bottom_navigation" />
</LinearLayout>
